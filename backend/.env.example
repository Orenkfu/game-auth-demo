# Discord OAuth
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/oauth/discord/callback

# Riot Games OAuth (RSO)
# Get these from https://developer.riotgames.com
# RGAPI-2801c5e9-63fb-485f-bd0d-d6fa338fdcb0
RIOT_CLIENT_ID=your_client_id
RIOT_CLIENT_SECRET=your_client_secret
RIOT_REDIRECT_URI=http://localhost:3000/oauth/riot/callback
