# CORS
CORS_ORIGIN=http://localhost:3000

# Token Encryption — 64-char hex (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a unique value per environment. Never reuse across prod/staging.
OAUTH_TOKEN_ENCRYPTION_KEY=6346618f9104091a5e0f29f271e90b05904b2b8902ba3b8e223c57aeb673cdee

# Redis
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# Postgres
USE_POSTGRES=false
DATABASE_URL=postgresql://gameauth:gameauth@localhost:5432/gameauth

# Discord OAuth
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/oauth/discord/callback

# Riot Games OAuth (RSO)
# Get these from https://developer.riotgames.com
RIOT_CLIENT_ID=your_client_id
RIOT_CLIENT_SECRET=your_client_secret
RIOT_REDIRECT_URI=http://localhost:3000/oauth/riot/callback

# Video Storage (S3-compatible)
# Local dev: uses MinIO via docker-compose (values below match docker-compose defaults)
# Production: remove STORAGE_ENDPOINT, set real AWS credentials and bucket
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=game-auth-videos
STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# STORAGE_MULTIPART_THRESHOLD_MB=50
# STORAGE_PART_SIZE_MB=10
# STORAGE_URL_EXPIRY_SECS=3600
# STORAGE_CDN_DOMAIN=https://cdn.example.com
